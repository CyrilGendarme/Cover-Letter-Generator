{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Cover Letter App",
      "type": "debugpy",
      "request": "launch",
      "module": "cover_letter_generator.main",
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Tests (pytest)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests",
        "-q"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${workspaceFolder}"
    }
  ]
}
